[FUNCTION_LIBRARY_1]
NAME=MovingAverage
COMMENT=Calculates the unweighted moving average of the physical input signal
PACKAGE_ID=FUP::{"Type":"Function","Root":"Global","Name":"MovingAverage","Properties":{"FunctionType":"Casl","Version":"1.0.0.0"}}
COUNT=44
1=// ----------------------------------------------------------------------------
2=// Function: MovingAverage()
3=//
4=// This function calculates the unweighted moving average value of the input 
5=// signal (physical value)
6=// ----------------------------------------------------------------------------
7=
8=function MovingAverage(var signal)
9={
10=  //! number of last measure values to be used for the calculation
11=  int smoothFactor = 4;  
12=
13=  // local variables
14=  unsigned int first = 1;
15=  double lastValues[100];
16=  double sum;
17=  unsigned int i;
18=  unsigned int index;
19=
20=  // initialize array with last values on start
21=  if (first) {
22=    first = 0;
23=
24=    if (smoothFactor > 100) {
25=      write("Error: Maximum avarage window size is 100!\n");
26=      smoothFactor = 100;
27=    }
28=
29=    sum = smoothFactor * signal;
30=    for (i = 0; i < smoothFactor; i++) {
31=      lastValues[i] = signal;
32=    } 
33=    index = 0;
34=    return signal;
35=  }
36=
37=  sum -= lastValues[index];
38=  sum += signal;
39=  lastValues[index] = signal;
40=  if (++index >= smoothFactor) {
41=    index = 0;
42=  }
43=  return sum / smoothFactor;
44=}

