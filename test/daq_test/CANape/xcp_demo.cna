[FUNCTION_1]
NAME=Dt
COMMENT=
COUNT=4
1=function Dt (x)
2={
3=  return diffTime(x);
4=}

[FUNCTION_2]
NAME=Check
COMMENT=
COUNT=21
1=
2=  function Check (x)
3={
4=  static double last = 0;
5=  double diff;
6=  
7=  diff = x-last;
8=  
9=   writef("counter = %g, last = %g");
10=
11=
12=  if (last+1 != x && x >= last) {
13=    writef("counter = %g, last = %g\n");
14=    return diff;
15=   
16=  }
17=   
18=  last = x;
19=  //cancel;
20=return 1;
21=}

